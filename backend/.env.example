# Copy to .env for local development. Never commit the real .env.
# --- Database (Render PostgreSQL connection string) ---
DATABASE_URL=postgresql+psycopg2://tasap:tasap@localhost:5432/tasap

# --- JWT signing secret (MUST be identical on API and frontend) ---
SECRET_KEY=change-me-to-a-long-random-string

# --- Supabase Storage (NOT AWS) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_BUCKET=tasap-uploads

# --- CORS: comma-separated list of allowed frontend origins ---
CORS_ORIGINS=http://localhost:3000

# --- Public base URL of this API service (used in links/exports) ---
APP_BASE_URL=http://localhost:8000
